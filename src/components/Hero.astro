---
const personalImageAlt = "José Manuel"
import Badge from "@/components/Badge.astro"
import LinkedInIcon from "@/components/icons/LinkedIn.astro"
import MailIcon from "@/components/icons/Mail.astro"
import SocialPill from "@/components/SocialPill.astro"
---

<div class="max-w-xl">
  <div class="flex gap-4 mb-4">
    <img
      class="rounded-full shadow-lg size-16"
      src="/avatar.png"
      alt={personalImageAlt}
    />
    <a
      href="https://www.linkedin.com/in/jos%C3%A9-manuel-romero-php-java-python-mysql-react-html-css/"
      target="_blank"
      rel="noopener"
      class="flex items-center transition md:justify-center md:hover:scale-105"
    >
      <Badge>Disponible para trabajar</Badge>
    </a>
  </div>
  <h1
    class="text-4xl font-bold tracking-tight text-gray-800 sm:text-5xl dark:text-white"
  >
    ¡Hola! soy José Manuel
  </h1>
  <p
    class="mt-6 text-xl text-gray-800 dark:[&>strong]:text-yellow-200 [&>strong]:text-yellow-500 [&>strong]:font-semibold dark:text-gray-300"
  >
    Cuento con 1 año de experiencia. <strong
      >Desarrollador de aplicaciones web</strong
    > de Madrid, España. Especializado en el desarrollo de páginas web accesibles, modernas y únicas.
  </p>
  <nav class="flex flex-wrap gap-4 mt-8">
    <SocialPill href="mailto:jmromero0912@gmail.com">
      <MailIcon class="size-4" />
      jmromero0912@gmail.com
    </SocialPill>
    <SocialPill href="https://www.linkedin.com/in/jos%C3%A9-manuel-romero-php-java-python-mysql-react-html-css/">
      <LinkedInIcon class="size-4" />
      LinkedIn
    </SocialPill>
  </nav>
</div>
